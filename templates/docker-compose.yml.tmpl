services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
      args:
        - VITE_BACKEND_URL=
        - VITE_API_KEY=${CLIENT_API_KEY:-}
        - VITE_COPILOT_NAME=${COPILOT_NAME:-__COPILOT_NAME__}
    expose:
      - "80"
    environment:
      - PORT=80
      - GROQ_API_KEY=${GROQ_API_KEY:-}
      - CLIENT_API_KEY=${CLIENT_API_KEY:-}
      - STT_URL=${STT_URL:-}
      - STT_HALLUCINATION_FILTER=${STT_HALLUCINATION_FILTER:-1}
      - QWEN3_TTS_URL=${QWEN3_TTS_URL:-}
      - POCKET_TTS_URL=${POCKET_TTS_URL:-}
      - LUXTTS_URL=${LUXTTS_URL:-}
      - VLLM_OMNI_TTS_URL=${VLLM_OMNI_TTS_URL:-}
      - ADMIN_PASSWORD=${ADMIN_PASSWORD:-admin}
    volumes:
      - persona-data:/app/data/persona
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "5"

volumes:
  persona-data:
