# check=skip=SecretsUsedInArgOrEnv
FROM node:22-slim AS builder
WORKDIR /app
COPY package.json package-lock.json* ./
# Cache-bust npm install when "latest" packages have new versions
ARG NPM_CACHE_BUST=0
RUN npm install --legacy-peer-deps
COPY . .
# Build-time Vite env vars passed as ARGs, written to .env.production
# so they don't persist as ENV in the final image.
# VITE_API_KEY is a client-side auth token (baked into JS bundle), not a secret.
ARG VITE_BACKEND_URL
ARG VITE_API_KEY
ARG VITE_COPILOT_NAME
RUN printf 'VITE_BACKEND_URL=%s\nVITE_API_KEY=%s\nVITE_COPILOT_NAME=%s\n' \
    "${VITE_BACKEND_URL}" "${VITE_API_KEY}" "${VITE_COPILOT_NAME}" > .env.production \
    && npx vite build

FROM nginx:alpine
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
